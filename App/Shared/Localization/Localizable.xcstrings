    "settings.section.backup.footer": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "JSON exports cover routine, hydration, housekeeping, and trips. Import is destructive — it replaces all data on this device. Document scans (Keychain) are not included."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las copias en JSON incluyen rutina, hidratación, tareas y viajes. Importar es destructivo — reemplaza todos los datos del dispositivo. Los documentos escaneados (Keychain) no se incluyen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les sauvegardes JSON couvrent routine, hydratation, tâches et voyages. L'import est destructif — il remplace toutes les données. Les documents scannés (Keychain) ne sont pas inclus."
          }
        }
      }
    },
