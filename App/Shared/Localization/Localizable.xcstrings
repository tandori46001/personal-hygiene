    "onboarding.welcome.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "personal-hygiene helps you follow your day with military precision: hygiene, meals, work, medication, sleep. We'll start with two example templates you can edit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "personal-hygiene te ayuda a seguir tu día con precisión militar: aseo, comidas, trabajo, medicación, sueño. Empezamos con dos plantillas de ejemplo que puedes editar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "personal-hygiene t'aide à suivre ta journée avec une précision militaire : hygiène, repas, travail, médicaments, sommeil. On commence avec deux modèles d'exemple que tu peux modifier."
          }
        }
      }
    },
